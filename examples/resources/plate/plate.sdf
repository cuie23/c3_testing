<?xml version="1.0"?>
<sdf version="1.7">
  <world name="plate_world">

    <model name="plate_model">

      <!-- Plate -->
      <link name="plate">
        <pose>0 0 0 0 0 0</pose>
        <inertial><mass>0.5</mass></inertial>
        <visual name="plate_visual">
          <geometry>
            <cylinder>
              <radius>0.5</radius>
              <length> 0.01 </length>
            </cylinder>
          </geometry>
          <material><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
        <collision name="plate_collision">
          <geometry>
            <cylinder>
              <radius>0.5</radius>
              <length> 0.01 </length>
            </cylinder>
          </geometry>
          <drake:proximity_properties>
            <drake:mu_static>0.5</drake:mu_static>
            <drake:mu_dynamic>0.4</drake:mu_dynamic>
          </drake:proximity_properties>
        </collision>
      </link>



      <joint name="plate_x" type="prismatic">
        <parent>world</parent>
        <child>link_x</child>
        <axis><xyz>1 0 0</xyz></axis>
      </joint>

      <link name="link_x"/>

      <joint name="plate_y" type="prismatic">
        <parent>link_x</parent>
        <child>link_y</child>
        <axis><xyz>0 1 0</xyz></axis>
      </joint>

      <link name="link_y"/>

      <joint name="plate_z" type="prismatic">
        <parent>link_y</parent>
        <child>plate</child>
        <axis><xyz>0 0 1</xyz></axis>
      </joint>



    </model>

  </world>
</sdf>
